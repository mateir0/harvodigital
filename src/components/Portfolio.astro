---
const projects = [
  {
    title: "Apex SaaS Analytics Platform",
    category: "Websites",
    image: "/portfolio-1.png",
    link: "#"
  },
  {
    title: "Aetheria Cosmetics Rebrand",
    category: "Branding",
    image: "/portfolio-2.png",
    link: "#"
  },
  {
    title: "Velocti Q2 Acquisition Campaign",
    category: "Ad Campaigns",
    image: "/portfolio-3.png",
    link: "#"
  },
  {
    title: "Chronos Visual Brand Curation",
    category: "Social Media Work",
    image: "/portfolio-4.png",
    link: "#"
  }
];
---
<section class="portfolio-section" id="portfolio">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2 class="section-title">Selected Portfolio</h2>
      <p class="section-subtitle">A curated collection of client work executing at the intersection of performance and aesthetics.</p>
    </div>
    
    <div class="portfolio-grid">
      {projects.map(project => (
        <a href={project.link} class="portfolio-item reveal-on-scroll">
          <div class="image-wrapper">
            <img src={project.image} alt={project.title} class="portfolio-img" loading="lazy" />
            <div class="hover-overlay"></div>
          </div>
          <div class="portfolio-meta">
            <span class="portfolio-category">{project.category}</span>
            <h3 class="portfolio-item-title">{project.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    padding-top: var(--space-y-section);
    padding-bottom: var(--space-y-section);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    max-width: 600px;
    margin-bottom: 64px;
  }

  .section-title {
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .portfolio-item {
    display: block;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius);
    overflow: hidden;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color var(--duration-smooth) var(--transition-smooth);
  }

  .portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-smooth) var(--transition-smooth);
  }

  .hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(11, 15, 25, 0.2);
    opacity: 1;
    transition: opacity var(--duration-smooth) var(--transition-smooth);
    pointer-events: none;
  }

  /* Hover States */
  .portfolio-item:hover .image-wrapper {
    border-color: var(--color-primary);
  }

  .portfolio-item:hover .portfolio-img {
    transform: scale(1.03);
  }

  .portfolio-item:hover .hover-overlay {
    background-color: rgba(11, 15, 25, 0.0);
  }

  .portfolio-meta {
    margin-top: 20px;
    padding: 0 4px;
  }

  .portfolio-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .portfolio-item-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text-primary);
    transition: color var(--duration-smooth) var(--transition-smooth);
  }

  .portfolio-item:hover .portfolio-item-title {
    color: var(--color-primary);
  }

  /* Responsive Rules */
  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    
    .section-header {
      margin-bottom: 48px;
    }
  }
</style>
