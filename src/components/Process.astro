---
const steps = [
  {
    num: "01",
    title: "Discovery Call",
    description: "We analyze your business objectives, target audience, and existing metrics to identify rapid growth bottlenecks."
  },
  {
    num: "02",
    title: "Strategy Planning",
    description: "We outline an execution roadmap specifying channels, messaging angles, asset requirements, and core target KPIs."
  },
  {
    num: "03",
    title: "Execution",
    description: "Our designers, developers, and copywriters deploy customized assets and launch initial marketing structures."
  },
  {
    num: "04",
    title: "Optimization",
    description: "We track performance data in real-time, executing A/B tests on creative variants, copy, and landing pages."
  },
  {
    num: "05",
    title: "Scaling Results",
    description: "Once high-performance channels are identified, we scale budgets and traffic to maximize customer acquisition volume."
  }
];
---
<section class="process-section" id="process">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2 class="section-title">Our Process</h2>
      <p class="section-subtitle">A structured, data-first methodology designed to take projects from initial discovery to measurable market growth.</p>
    </div>
    
    <div class="process-timeline reveal-on-scroll">
      <!-- Horizontal connector line for desktop -->
      <div class="timeline-line"></div>
      
      <div class="steps-container">
        {steps.map(step => (
          <div class="step-card">
            <div class="step-badge">{step.num}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding-top: var(--space-y-section);
    padding-bottom: var(--space-y-section);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .section-header {
    max-width: 600px;
    margin-bottom: 80px;
  }

  .section-title {
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  /* Timeline structure */
  .process-timeline {
    position: relative;
    width: 100%;
  }

  /* Horizontal line on desktop */
  .timeline-line {
    position: absolute;
    top: 24px; /* Align with middle of the badge */
    left: 10%;
    right: 10%;
    height: 1px;
    background-color: var(--color-border);
    z-index: 1;
  }

  .steps-container {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    position: relative;
    z-index: 2;
  }

  .step-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .step-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: border-color var(--duration-smooth) var(--transition-smooth), 
                color var(--duration-smooth) var(--transition-smooth);
  }

  .step-card:hover .step-badge {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .step-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--color-text-primary);
  }

  .step-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Responsive Rules */
  @media (max-width: 1024px) {
    .steps-container {
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    .timeline-line {
      left: 24px;
      top: 0;
      bottom: 0;
      width: 1px;
      height: 100%;
    }
    
    .steps-container {
      flex-direction: column;
      gap: 40px;
    }

    .step-card {
      flex-direction: row;
      gap: 20px;
      align-items: flex-start;
    }

    .step-badge {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .step-title {
      margin-top: 10px;
      margin-bottom: 8px;
    }
    
    .section-header {
      margin-bottom: 56px;
    }
  }
</style>
