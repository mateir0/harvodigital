---
const pricingPlans = [
  {
    name: "Starter",
    price: "$99",
    period: "/mo",
    desc: "Essential digital services for growing businesses looking to establish a search and visual presence.",
    features: [
      "Weekly organic content scheduling",
      "On-page SEO setup & optimization",
      "Standard monthly performance analytics",
      "Email support (24h turnaround)",
      "Standard website maintenance"
    ],
    buttonText: "Start Starter Plan",
    featured: false
  },
  {
    name: "Growth",
    price: "$299",
    period: "/mo",
    desc: "Bespoke optimization and ad operations designed to aggressively drive pipeline leads and conversions.",
    features: [
      "Comprehensive SEO audit & ranking optimization",
      "Meta & Google Ad Management (up to $5k spend)",
      "2 Custom high-retention video ad edits / mo",
      "Direct Slack channel communication",
      "Bi-weekly data-led performance reviews"
    ],
    buttonText: "Start Growth Plan",
    featured: true
  },
  {
    name: "Premium",
    price: "$599",
    period: "/mo",
    desc: "Comprehensive visual branding, performance growth scaling, and dedicated engineering resources.",
    features: [
      "Full-funnel paid advertising (unlimited spend)",
      "Branding guidelines & graphic design support",
      "Custom React/Astro web design & development",
      "24/7 Dedicated WhatsApp & phone support",
      "Custom live analytics tracking dashboard"
    ],
    buttonText: "Start Premium Plan",
    featured: false
  }
];
---
<section class="pricing-section">
  <div class="container">
    <div class="section-header reveal-on-scroll">
      <h2 class="section-title">Investment Plans</h2>
      <p class="section-subtitle">Transparent pricing retainers scaled to support different growth stages. Select a level to begin accelerating.</p>
    </div>
    
    <div class="pricing-grid">
      {pricingPlans.map(plan => (
        <div class={`pricing-card ${plan.featured ? 'featured' : ''} reveal-on-scroll`}>
          {plan.featured && <div class="featured-badge">Recommended</div>}
          
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-price-row">
              <span class="plan-price">{plan.price}</span>
              <span class="plan-period">{plan.period}</span>
            </div>
            <p class="plan-desc">{plan.desc}</p>
          </div>
          
          <ul class="plan-features">
            {plan.features.map(feature => (
              <li class="feature-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon-pricing"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          
          <div class="plan-footer">
            <a href="#contact" class={`btn w-100 ${plan.featured ? 'btn-primary' : 'btn-secondary'}`}>
              {plan.buttonText}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding-top: var(--space-y-section);
    padding-bottom: var(--space-y-section);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    max-width: 600px;
    margin-bottom: 64px;
  }

  .section-title {
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: stretch;
  }

  .pricing-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 40px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform var(--duration-smooth) var(--transition-smooth), 
                border-color var(--duration-smooth) var(--transition-smooth);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
  }

  /* Subtle border highlight for featured card */
  .pricing-card.featured {
    border-color: var(--color-primary);
  }

  .featured-badge {
    position: absolute;
    top: 20px;
    right: 24px;
    background-color: rgba(30, 94, 255, 0.1);
    color: var(--color-primary);
    border: 1px solid rgba(30, 94, 255, 0.2);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    border-radius: 20px;
  }

  .plan-header {
    margin-bottom: 32px;
  }

  .plan-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 16px;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    margin-bottom: 16px;
  }

  .plan-price {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .plan-period {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-left: 4px;
  }

  .plan-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
    flex-grow: 1;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .check-icon-pricing {
    width: 14px;
    height: 14px;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .plan-footer {
    margin-top: auto;
  }

  .w-100 {
    width: 100%;
  }

  /* Responsive Rules */
  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .pricing-card {
      padding: 32px;
    }
    
    .section-header {
      margin-bottom: 48px;
    }
  }
</style>
