---
const benefits = [
  {
    title: "Data-driven strategies",
    description: "We make decisions based on concrete analytics, not guesswork. Comprehensive tracking is deployed in every client project."
  },
  {
    title: "Fast communication",
    description: "No radio silence or communication delays. Get a dedicated Slack channel or direct WhatsApp updates weekly."
  },
  {
    title: "Affordable pricing",
    description: "Enterprise-grade performance and custom execution without the bloated overhead of traditional big-name agencies."
  },
  {
    title: "High ROI marketing",
    description: "Every campaign is optimized for customer acquisition cost (CAC) reduction and lifetime value (LTV) growth."
  },
  {
    title: "Custom strategies for each client",
    description: "We perform dedicated competitor research and industry gap analysis to build a bespoke playbook for your brand."
  }
];
---
<section class="why-us-section" id="why-us">
  <div class="container grid-12 why-us-container">
    <!-- Left side: Abstract dashboard illustration -->
    <div class="why-us-visual reveal-on-scroll">
      <div class="illustration-card">
        <svg viewBox="0 0 440 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="dashboard-svg">
          <!-- Card Background -->
          <rect width="440" height="320" rx="12" fill="#111827" stroke="#1F2937" stroke-width="1.5" />
          
          <!-- Grid Lines -->
          <line x1="40" y1="60" x2="400" y2="60" stroke="#1F2937" stroke-width="1" />
          <line x1="40" y1="120" x2="400" y2="120" stroke="#1F2937" stroke-width="1" />
          <line x1="40" y1="180" x2="400" y2="180" stroke="#1F2937" stroke-width="1" />
          <line x1="40" y1="240" x2="400" y2="240" stroke="#1F2937" stroke-width="1" />
          
          <!-- Mock Chart 1: Curving Metric Line -->
          <path d="M40 220 C 100 230, 150 140, 200 130 C 250 120, 300 70, 400 80" stroke="#1F2937" stroke-width="2" stroke-dasharray="4 4" />
          
          <!-- Mock Chart 2: Primary Rising Line -->
          <path d="M40 240 Q 120 230, 180 150 T 320 100 T 400 65" stroke="#1E5EFF" stroke-width="3" stroke-linecap="round" />
          
          <!-- Node Dots on Curve -->
          <circle cx="180" cy="150" r="5" fill="#FFFFFF" stroke="#1E5EFF" stroke-width="2" />
          <circle cx="320" cy="100" r="5" fill="#FFFFFF" stroke="#1E5EFF" stroke-width="2" />
          <circle cx="400" cy="65" r="5" fill="#FFFFFF" stroke="#1E5EFF" stroke-width="2" />
          
          <!-- Highlighted Area under curve (subtle gradient/color overlay) -->
          <path d="M40 240 Q 120 230, 180 150 T 320 100 T 400 65 V 240 H 40 Z" fill="rgba(30, 94, 255, 0.03)" />
          
          <!-- Small Card Stat Overlay -->
          <g transform="translate(260, 160)">
            <rect width="140" height="70" rx="8" fill="#1B2436" stroke="#1F2937" stroke-width="1.5" />
            <text x="15" y="30" fill="#AAB2C8" font-family="'Sora', sans-serif" font-size="11" font-weight="600">CONVERSION RATE</text>
            <text x="15" y="52" fill="#FFFFFF" font-family="'Sora', sans-serif" font-size="20" font-weight="700">+342%</text>
            <circle cx="120" cy="45" r="6" fill="#1E5EFF" />
          </g>
          
          <!-- Bullet representation in visual -->
          <rect x="40" y="270" width="80" height="12" rx="4" fill="#1B2436" />
          <circle cx="135" cy="276" r="4" fill="#1E5EFF" />
          <rect x="150" y="270" width="60" height="12" rx="4" fill="#1F2937" />
          <rect x="225" y="270" width="75" height="12" rx="4" fill="#1F2937" />
        </svg>
      </div>
    </div>
    
    <!-- Right side: Benefits points -->
    <div class="why-us-content reveal-on-scroll">
      <h2 class="section-title">Why Choose Us</h2>
      <p class="why-us-lead">
        We bridge the gap between high-end visual aesthetics and technical execution to deliver tangible business outcomes.
      </p>
      
      <div class="benefits-list">
        {benefits.map(benefit => (
          <div class="benefit-item">
            <div class="benefit-icon-wrapper">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="benefit-text">
              <h3 class="benefit-title">{benefit.title}</h3>
              <p class="benefit-desc">{benefit.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .why-us-section {
    padding-top: var(--space-y-section);
    padding-bottom: var(--space-y-section);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .why-us-container {
    align-items: center;
  }

  .why-us-visual {
    grid-column: span 6;
    display: flex;
    justify-content: center;
  }

  .illustration-card {
    width: 100%;
    max-width: 440px;
    background-color: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .dashboard-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .why-us-content {
    grid-column: span 6;
  }

  .why-us-lead {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 36px;
  }

  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .benefit-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .benefit-icon-wrapper {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    background-color: rgba(30, 94, 255, 0.08);
    border-radius: 50%;
    margin-top: 2px;
  }

  .check-icon {
    width: 12px;
    height: 12px;
  }

  .benefit-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--color-text-primary);
  }

  .benefit-desc {
    font-size: 0.925rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Responsive Rules */
  @media (max-width: 1024px) {
    .why-us-visual {
      grid-column: span 5;
    }
    
    .why-us-content {
      grid-column: span 7;
    }
  }

  @media (max-width: 768px) {
    .why-us-container {
      display: flex;
      flex-direction: column;
      gap: 56px;
    }
    
    .why-us-visual {
      width: 100%;
      order: 2; /* Put illustration below text on mobile */
    }

    .illustration-card {
      max-width: 380px;
    }
  }
</style>
