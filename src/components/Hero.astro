---

---

<section class="hero-section">
  <!-- Layer 1: background dark base (already page bg, but we keep a local layer for depth consistency) -->
  <div class="hero-bg" aria-hidden="true"></div>

  <!-- Layer 2: 3D sculpture behind content -->
  <div class="hero-3d-layer" aria-hidden="true">
    <div class="canvas-wrapper">
      <canvas id="hero-3d-canvas" width="500" height="500"></canvas>
    </div>
  </div>

  <!-- Layer 3: subtle overlay for premium readability -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Layer 4: front content -->
  <div class="container hero-container grid-12">
    <div class="hero-content reveal-on-scroll">
      <div class="agency-tag">HARVO DIGITAL</div>
      <h1 class="hero-headline">
        Grow Faster.<br /><span class="text-primary">Scale Smarter.</span>
      </h1>
      <p class="hero-subheadline">
        We help businesses scale through performance-driven digital marketing,
        SEO, web development, branding, and paid advertising.
      </p>
      <div class="hero-cta-group">
        <a href="#contact" class="btn btn-primary">Get Started</a>
        <a href="#portfolio" class="btn btn-secondary">View Portfolio</a>
      </div>
    </div>

    <!-- Keep grid right column empty to avoid layout redesign; 3D is absolutely layered behind -->
    <div class="hero-visual-space" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: calc(var(--space-y-section) + 80px);
    padding-bottom: var(--space-y-section);
    position: relative;
    overflow: hidden;
  }

  /* Local layering context for premium depth */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        1200px 600px at 50% 30%,
        rgba(30, 94, 255, 0.1),
        transparent 55%
      ),
      linear-gradient(180deg, rgba(11, 15, 25, 1) 0%, rgba(11, 15, 25, 1) 100%);
    z-index: 0;
    pointer-events: none;
  }

  .hero-3d-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(11, 15, 25, 0.92) 0%,
      rgba(11, 15, 25, 0.7) 35%,
      rgba(11, 15, 25, 0.35) 60%,
      rgba(11, 15, 25, 0.6) 100%
    );
  }

  .hero-container {
    align-items: center;
    position: relative;
    z-index: 3;
  }

  .hero-content {
    grid-column: span 6;
    position: relative;
    z-index: 3;
  }

  /* Intentionally blank space to keep existing grid without re-layout */
  .hero-visual-space {
    grid-column: span 6;
  }

  .agency-tag {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .text-primary {
    color: var(--color-primary);
  }

  .hero-subheadline {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .hero-cta-group {
    display: flex;
    gap: 16px;
  }

  /* Canvas Visual */
  .canvas-wrapper {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    transform: translateX(6px) translateY(6px);
    filter: blur(0.6px);
    opacity: 0.95;
  }

  #hero-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }

  #hero-3d-canvas:active {
    cursor: grabbing;
  }

  /* Responsive Rules */
  @media (max-width: 1024px) {
    .hero-content {
      grid-column: span 7;
    }
    .hero-visual {
      grid-column: span 5;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 120px;
      padding-bottom: 60px;
    }

    .hero-container {
      display: flex;
      flex-direction: column;
      text-align: center;
      gap: 48px;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-subheadline {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-cta-group {
      width: 100%;
      flex-direction: column;
      gap: 12px;
    }

    .hero-cta-group .btn {
      width: 100%;
    }

    .canvas-wrapper {
      max-width: 320px;
    }
  }
</style>

<script>
  const setup3DLogo = () => {
    const canvas = document.getElementById(
      "hero-3d-canvas",
    ) as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Device Pixel Ratio for crisp rendering on retina displays
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);

    const width = rect.width;
    const height = rect.height;

    // Define 3D vertices for the HARVO abstract geometric H
    // Coordinates range from -2 to +2
    const scale = 36;
    const rawVertices = [
      // Left bar (8 vertices)
      { x: -1.4, y: -2.2, z: -0.6 },
      { x: -0.6, y: -2.2, z: -0.6 },
      { x: -0.6, y: 2.2, z: -0.6 },
      { x: -1.4, y: 2.2, z: -0.6 },
      { x: -1.4, y: -2.2, z: 0.6 },
      { x: -0.6, y: -2.2, z: 0.6 },
      { x: -0.6, y: 2.2, z: 0.6 },
      { x: -1.4, y: 2.2, z: 0.6 },

      // Right bar (8 vertices)
      { x: 0.6, y: -2.2, z: -0.6 },
      { x: 1.4, y: -2.2, z: -0.6 },
      { x: 1.4, y: 2.2, z: -0.6 },
      { x: 0.6, y: 2.2, z: -0.6 },
      { x: 0.6, y: -2.2, z: 0.6 },
      { x: 1.4, y: -2.2, z: 0.6 },
      { x: 1.4, y: 2.2, z: 0.6 },
      { x: 0.6, y: 2.2, z: 0.6 },

      // Middle cross bar (8 vertices)
      { x: -0.6, y: -0.4, z: -0.4 },
      { x: 0.6, y: -0.4, z: -0.4 },
      { x: 0.6, y: 0.4, z: -0.4 },
      { x: -0.6, y: 0.4, z: -0.4 },
      { x: -0.6, y: -0.4, z: 0.4 },
      { x: 0.6, y: -0.4, z: 0.4 },
      { x: 0.6, y: 0.4, z: 0.4 },
      { x: -0.6, y: 0.4, z: 0.4 },
    ];

    // Define edges connecting the vertices
    const edges = [
      // Left bar vertical edges
      [0, 1],
      [1, 2],
      [2, 3],
      [3, 0],
      [4, 5],
      [5, 6],
      [6, 7],
      [7, 4],
      [0, 4],
      [1, 5],
      [2, 6],
      [3, 7],

      // Right bar vertical edges
      [8, 9],
      [9, 10],
      [10, 11],
      [11, 8],
      [12, 13],
      [13, 14],
      [14, 15],
      [15, 12],
      [8, 12],
      [9, 13],
      [10, 14],
      [11, 15],

      // Middle connector edges
      [16, 17],
      [17, 18],
      [18, 19],
      [19, 16],
      [20, 21],
      [21, 22],
      [22, 23],
      [23, 20],
      [16, 20],
      [17, 21],
      [18, 22],
      [19, 23],
    ];

    // Target angles for soft premium rotation (slower + calmer)
    let angleX = 0.32;
    let angleY = -0.52;
    let angleZ = 0.08;

    let targetAngleX = 0.32;
    let targetAngleY = -0.52;

    // Mouse movement listeners for interactive tilt
    let mouseX = 0;
    let mouseY = 0;
    let isHovering = false;

    const handleMouseMove = (e: MouseEvent) => {
      const bounds = canvas.getBoundingClientRect();
      const x = e.clientX - bounds.left - width / 2;
      const y = e.clientY - bounds.top - height / 2;

      // Calculate target rotation based on hover position (subtle, agency-grade tilt)
      targetAngleY = (x / (width / 2)) * 0.8;
      targetAngleX = -(y / (height / 2)) * 0.8;
    };

    const handleMouseEnter = () => {
      isHovering = true;
    };

    const handleMouseLeave = () => {
      isHovering = false;
      targetAngleX = 0.4;
      targetAngleY = -0.6;
    };

    canvas.addEventListener("mousemove", (e) => {
      // Very subtle parallax: only influence target angles slightly
      const bounds = canvas.getBoundingClientRect();
      const x = e.clientX - bounds.left - width / 2;
      const y = e.clientY - bounds.top - height / 2;

      targetAngleY = (x / (width / 2)) * 0.35;
      targetAngleX = -(y / (height / 2)) * 0.35;
    });

    canvas.addEventListener("mouseenter", handleMouseEnter);
    canvas.addEventListener("mouseleave", handleMouseLeave);

    // Render loop
    const render = () => {
      ctx.clearRect(0, 0, width, height);

      // Smooth inertia: drift towards targets (slower for premium feel)
      angleX += (targetAngleX - angleX) * 0.028;
      angleY += (targetAngleY - angleY) * 0.028;

      // Constant slow background rotation on Y axis when not active
      if (!isHovering) {
        targetAngleY += 0.0016;
      }

      // Rotate nodes and store project 2D points
      const projected: { x: number; y: number; z: number }[] = [];

      rawVertices.forEach((v) => {
        // Rotate X
        let y1 = v.y * Math.cos(angleX) - v.z * Math.sin(angleX);
        let z1 = v.y * Math.sin(angleX) + v.z * Math.cos(angleX);

        // Rotate Y
        let x2 = v.x * Math.cos(angleY) + z1 * Math.sin(angleY);
        let z2 = -v.x * Math.sin(angleY) + z1 * Math.cos(angleY);

        // Rotate Z
        let x3 = x2 * Math.cos(angleZ) - y1 * Math.sin(angleZ);
        let y3 = x2 * Math.sin(angleZ) + y1 * Math.cos(angleZ);

        // Perspective Projection (subtle scale relative to Z depth)
        const perspective = 300;
        const scaleFactor = perspective / (perspective + z2);

        projected.push({
          x: x3 * scale * scaleFactor + width / 2,
          y: y3 * scale * scaleFactor + height / 2,
          z: z2, // Keep depth for sorting or coloring
        });
      });

      // Draw Edges (sorted by average depth so closer edges overlay correctly)
      const sortedEdges = edges
        .map((edge, index) => {
          const p1 = projected[edge[0]];
          const p2 = projected[edge[1]];
          const avgZ = (p1.z + p2.z) / 2;
          return { edge, avgZ, index };
        })
        .sort((a, b) => b.avgZ - a.avgZ); // Deepest first

      sortedEdges.forEach(({ edge }) => {
        const p1 = projected[edge[0]];
        const p2 = projected[edge[1]];

        // Determine edge color based on depth Z
        // Higher Z is deeper (away from camera), lower Z is closer (towards camera)
        // Normalize Z range approximately from -3 to 3 (scaled by scale)
        const depthVal = (p1.z + p2.z) / 2; // Closer to -2 means closer to screen

        // Map depth to opacity/color
        // Closer: bright blue highlight; farther: dark slate gray
        const minZ = -2.5;
        const maxZ = 2.5;
        let factor = (depthVal - minZ) / (maxZ - minZ);
        factor = Math.max(0, Math.min(1, factor)); // Clamp 0-1

        // Interpolate color: closer (factor -> 0) is blue, farther (factor -> 1) is dark grey
        const r = Math.round(30 + (31 - 30) * factor);
        const g = Math.round(94 + (41 - 94) * factor);
        const b = Math.round(255 + (55 - 255) * factor);
        const alpha = 0.8 - factor * 0.5; // Closer is more visible

        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p2.x, p2.y);
        ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx.lineWidth = factor < 0.4 ? 1.5 : 1.0;
        ctx.stroke();
      });

      // Draw Nodes (Vertices)
      projected.forEach((p) => {
        // Map depth to point size and color
        const minZ = -2.5;
        const maxZ = 2.5;
        let factor = (p.z - minZ) / (maxZ - minZ);
        factor = Math.max(0, Math.min(1, factor));

        const size = 3.5 * (1 - factor * 0.6);
        ctx.beginPath();
        ctx.arc(p.x, p.y, size, 0, Math.PI * 2);

        if (factor < 0.3) {
          // Glow effect on close vertices
          ctx.shadowBlur = 8;
          ctx.shadowColor = "rgba(30, 94, 255, 0.8)";
          ctx.fillStyle = "#FFFFFF";
        } else {
          ctx.shadowBlur = 0;
          ctx.fillStyle = `rgba(30, 94, 255, ${1 - factor * 0.7})`;
        }

        ctx.fill();
        ctx.shadowBlur = 0; // Reset
      });

      requestAnimationFrame(render);
    };

    render();

    // Resize Handler
    const handleResize = () => {
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.resetTransform();
      ctx.scale(dpr, dpr);
    };

    window.addEventListener("resize", handleResize);
  };

  // Run on mount
  document.addEventListener("DOMContentLoaded", setup3DLogo);
  document.addEventListener("astro:after-swap", setup3DLogo);
</script>
