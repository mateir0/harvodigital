---
const currentYear = new Date().getFullYear();

const navLinks = [
  { name: "Home", href: "#" },
  { name: "Services", href: "#services" },
  { name: "Portfolio", href: "#portfolio" },
  { name: "About Us", href: "#why-us" },
  { name: "Contact", href: "#contact" }
];

const services = [
  { name: "Search Engine Optimization", href: "#services" },
  { name: "Social Media Marketing", href: "#services" },
  { name: "Web Development", href: "#services" },
  { name: "Graphic Design", href: "#services" },
  { name: "Video Editing", href: "#services" },
  { name: "Paid Advertising", href: "#services" }
];

const socials = [
  { 
    name: "LinkedIn", 
    href: "https://linkedin.com", 
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>` 
  },
  { 
    name: "Twitter", 
    href: "https://twitter.com", 
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>` 
  },
  { 
    name: "Instagram", 
    href: "https://instagram.com", 
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>` 
  }
];
---

<footer class="footer">
  <div class="container footer-container grid-12">
    <!-- Brand Info -->
    <div class="footer-brand reveal-on-scroll">
      <a href="#" class="logo">
        HARVO<span>DIGITAL</span>
      </a>
      <p class="brand-desc">
        Grow Faster. Scale Smarter. Performance-driven digital marketing and custom engineering for high-growth businesses.
      </p>
      <div class="social-links">
        {socials.map(social => (
          <a href={social.href} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label={social.name} set:html={social.icon} />
        ))}
      </div>
    </div>

    <!-- Quick Navigation -->
    <div class="footer-links-col reveal-on-scroll">
      <h4 class="footer-col-title">Navigation</h4>
      <nav class="footer-nav">
        {navLinks.map(link => (
          <a href={link.href} class="footer-link">{link.name}</a>
        ))}
      </nav>
    </div>

    <!-- Services -->
    <div class="footer-links-col reveal-on-scroll">
      <h4 class="footer-col-title">Services</h4>
      <nav class="footer-nav">
        {services.map(service => (
          <a href={service.href} class="footer-link">{service.name}</a>
        ))}
      </nav>
    </div>

    <!-- Contact details summary -->
    <div class="footer-links-col reveal-on-scroll">
      <h4 class="footer-col-title">Office</h4>
      <p class="office-info">
        London, UK &amp; Remote
      </p>
      <p class="office-email">
        <a href="mailto:hello@harvo.digital" class="footer-link-highlight">hello@harvo.digital</a>
      </p>
      <p class="office-hours">
        Mon — Fri, 9 AM — 6 PM GMT
      </p>
    </div>
  </div>

  <!-- Copyright / Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p class="copyright">&copy; {currentYear} HARVO DIGITAL. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href="#" class="footer-sublink">Privacy Policy</a>
        <a href="#" class="footer-sublink">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-top: 80px;
    margin-top: auto;
  }

  .footer-container {
    padding-bottom: 60px;
  }

  .footer-brand {
    grid-column: span 4;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    display: inline-flex;
    align-items: center;
    margin-bottom: 20px;
  }

  .logo span {
    color: var(--color-primary);
    font-weight: 400;
    margin-left: 2px;
  }

  .brand-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 300px;
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-smooth) var(--transition-smooth);
  }

  .social-btn :global(svg) {
    width: 18px;
    height: 18px;
  }

  .social-btn:hover {
    color: var(--color-text-primary);
    border-color: var(--color-primary);
    background-color: rgba(30, 94, 255, 0.05);
    transform: translateY(-2px);
  }

  .footer-links-col {
    grid-column: span 2.66;
  }
  
  /* Layout adjustments for better column fitting on 12-grid */
  .footer-links-col:nth-of-type(2) {
    grid-column: span 2;
  }
  .footer-links-col:nth-of-type(3) {
    grid-column: span 3.5;
  }
  .footer-links-col:nth-of-type(4) {
    grid-column: span 2.5;
  }

  .footer-col-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    margin-bottom: 24px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    display: inline-block;
    transition: color var(--duration-smooth) var(--transition-smooth);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .office-info, .office-hours {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .office-email {
    margin-bottom: 8px;
  }

  .footer-link-highlight {
    font-size: 0.9rem;
    color: var(--color-text-primary);
    font-weight: 600;
    transition: color var(--duration-smooth) var(--transition-smooth);
  }

  .footer-link-highlight:hover {
    color: var(--color-primary);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 30px 0;
    font-size: 0.825rem;
    color: var(--color-text-secondary);
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom-links {
    display: flex;
    gap: 24px;
  }

  .footer-sublink {
    transition: color var(--duration-smooth) var(--transition-smooth);
  }

  .footer-sublink:hover {
    color: var(--color-primary);
  }

  /* Responsive Rules */
  @media (max-width: 1024px) {
    .footer-brand {
      grid-column: span 12;
      margin-bottom: 40px;
    }

    .footer-links-col:nth-of-type(2),
    .footer-links-col:nth-of-type(3),
    .footer-links-col:nth-of-type(4) {
      grid-column: span 4;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding-top: 60px;
    }

    .footer-container {
      gap: 40px;
    }

    .footer-links-col:nth-of-type(2),
    .footer-links-col:nth-of-type(3),
    .footer-links-col:nth-of-type(4) {
      grid-column: span 12;
    }

    .footer-col-title {
      margin-bottom: 16px;
    }

    .footer-bottom-container {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
